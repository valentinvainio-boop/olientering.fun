<!DOCTYPE html>
<html lang="sv">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ölientering | Matematik-utmaningen</title>
    <style>
        :root {
            --bg: #ffffff;
            --text: #1a1a1a;
            --accent: #000000;
        }
        body {
            font-family: 'Helvetica', 'Arial', sans-serif;
            background-color: var(--bg);
            color: var(--text);
            margin: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            min-height: 100vh;
            padding: 20px;
        }
        header {
            font-size: 2.5rem;
            font-weight: 400;
            letter-spacing: -1px;
            margin-bottom: 50px;
            margin-top: 20px;
        }
        .step {
            display: none;
            max-width: 500px;
            width: 100%;
            text-align: center;
            animation: fadeIn 0.5s ease;
        }
        .step.active { display: block; }

        h2 { font-size: 1.5rem; margin-bottom: 20px; }
        
        input {
            padding: 15px;
            font-size: 1.2rem;
            width: 80%;
            border: 2px solid #eee;
            border-radius: 8px;
            outline: none;
            margin-bottom: 20px;
        }
        
        button {
            padding: 15px 30px;
            background: var(--accent);
            color: white;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-size: 1rem;
        }

        .sortable-item {
            background: #f0f0f0;
            padding: 15px;
            margin: 10px 0;
            border-radius: 8px;
            cursor: grab;
            border: 1px solid #ddd;
        }

        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        
        #final-screen { font-size: 5rem; font-weight: bold; color: var(--accent); }
    </style>
</head>
<body>

    <header>ölientering</header>

    <div id="step-1" class="step active">
        <h2>Vad är derivatan av f(x) = 15x² + 10x när x = 3?</h2>
        <input type="number" id="ans-1" placeholder="Svara här...">
        <br>
        <button onclick="checkStep1()">Fortsätt</button>
    </div>

    <div id="step-2" class="step">
        <h2>Sortera från minst till störst:</h2>
        <p>(Dra inte, skriv bara svaret på nästa fråga)</p>
        <div class="sortable-item">A: 15 * 10</div>
        <div class="sortable-item">B: 2^7</div>
        <div class="sortable-item">C: √10000</div>
        <input type="text" id="ans-2" placeholder="Skriv ordningen (t.ex. CBA)">
        <br>
        <button onclick="checkStep2()">Kontrollera</button>
    </div>

    <div id="step-3" class="step">
        <h2>Slutgiltiga frågan: Vad är 400 * 2?</h2>
        <input type="number" id="ans-3" placeholder="Svara här...">
        <br>
        <button onclick="checkStep3()">Slutför</button>
    </div>

    <div id="step-final" class="step">
        <h2>Resultat:</h2>
        <div id="final-screen">800</div>
        <p>Du klarade Ölientering-testet.</p>
    </div>

    <script>
        function showStep(stepNum) {
            document.querySelectorAll('.step').forEach(s => s.classList.remove('active'));
            document.getElementById('step-' + stepNum).classList.add('active');
        }

        function checkStep1() {
            // Derivatan är 30x + 10. Vid x=3: 30(3) + 10 = 100
            if (document.getElementById('ans-1').value == "100") {
                showStep(2);
            } else {
                alert("Fel svar, försök igen!");
            }
        }

        function checkStep2() {
            // A=150, B=128, C=100. Ordning: CBA
            if (document.getElementById('ans-2').value.toUpperCase() == "CBA") {
                showStep(3);
            } else {
                alert("Fel ordning!");
            }
        }

        function checkStep3() {
            if (document.getElementById('ans-3').value == "800") {
                showStep('final');
            } else {
                alert("Nära nu! Vad blir 400 * 2?");
            }
        }
    </script>

</body>
</html>

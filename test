<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>The Wealth Experiment</title>
    <style>
        :root { --primary: #2ecc71; --bg: #ffffff; }
        body { font-family: sans-serif; background: var(--bg); display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100vh; margin: 0; transition: 0.3s; }
        #money-display { font-size: 4rem; font-weight: 800; color: var(--primary); margin-bottom: 20px; }
        .main-button { 
            padding: 25px 50px; font-size: 1.5rem; font-weight: bold; cursor: pointer; 
            border: none; border-radius: 15px; background: var(--primary); color: white;
            box-shadow: 0 8px #27ae60; transition: 0.1s; 
        }
        .main-button:active { transform: translateY(4px); box-shadow: 0 4px #27ae60; }
        .stats { margin-top: 20px; color: #7f8c8d; font-size: 1.2rem; }
    </style>
</head>
<body>

    <div id="money-display">$0</div>
    <button class="main-button" onclick="handleButtonClick()">GET $1,000,000</button>
    <div class="stats">Clicks: <span id="click-count">0</span></div>

    <script>
        // Use localStorage so your progress is saved!
        let money = parseInt(localStorage.getItem('money')) || 0;
        let clicks = parseInt(localStorage.getItem('clicks')) || 0;

        // Function to update the screen
        function updateUI() {
            document.getElementById('money-display').innerText = "$" + money.toLocaleString();
            document.getElementById('click-count').innerText = clicks;
        }

        function handleButtonClick() {
            money += 1000000;
            clicks += 1;
            
            // Save to browser memory
            localStorage.setItem('money', money);
            localStorage.setItem('clicks', clicks);
            
            updateUI();
        }

        // Run this when the page loads
        updateUI();
    </script>
</body>
</html>
